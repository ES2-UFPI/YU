generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model WellnessGoal {
  id               String   @id @db.VarChar(64)
  name             String   @db.VarChar(120)
  shortDescription String   @map("short_description") @db.VarChar(255)
  icon             String   @db.VarChar(80)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  userGoal     UserGoal[]
  goalProgress GoalProgress[]

  @@map("wellness_goals")
}

model UserGoal {
  id      String   @id @default(uuid())
  userId  String
  goalId  String
  savedAt DateTime @default(now())
  active  Boolean  @default(true)

  wellnessGoal WellnessGoal @relation(fields: [goalId], references: [id])

  @@unique([userId, goalId])
}

model UserLocation {
  id         String   @id @default(uuid())
  userId     String
  latitude   Float
  longitude  Float
  capturedAt DateTime @default(now())

  @@map("user_locations")
}

model GoalProgress {
  id          String   @id @default(uuid())
  userId      String
  goalId      String
  completedAt DateTime @default(now()) @db.Date

  wellnessGoal WellnessGoal @relation(fields: [goalId], references: [id])

  @@unique([userId, goalId, completedAt])
  @@map("goal_progress")
}
