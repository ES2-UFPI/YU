generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model WellnessGoal {
  id               String   @id @db.VarChar(64)
  name             String   @db.VarChar(120)
  shortDescription String   @map("short_description") @db.VarChar(255)
  icon             String   @db.VarChar(80)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  userGoal UserGoal[]

  @@map("wellness_goals")
}

model UserGoal {
  id      String   @id @default(uuid())
  userId  String
  goalId  String
  savedAt DateTime @default(now())
  active  Boolean  @default(true)

  wellnessGoal WellnessGoal @relation(fields: [goalId], references: [id])

  @@unique([userId, goalId])
}

model UserLocation {
  id         String   @id @default(uuid())
  userId     String
  latitude   Float
  longitude  Float
  capturedAt DateTime @default(now())

  @@map("user_locations")
}

model SuggestionProgress {
  id           String   @id @default(uuid())
  userId       String
  suggestionId String
  completedAt  DateTime @default(now()) @db.Date

  @@unique([userId, suggestionId, completedAt])
  @@map("suggestion_progress")
}

model WeatherData {
  id          String   @id @default(uuid())
  userId      String
  temperature Float
  condition   String
  latitude    Float
  longitude   Float
  fetchedAt   DateTime @default(now())

  @@map("weather_data")
}
